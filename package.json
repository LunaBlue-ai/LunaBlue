{
  "name": "lunablue",
  "version": "0.1.0",
  "description": "Cross-platform multi-LLM orchestration framework with embedded offline AI capabilities",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "npm run build && node dist/setup/install.js",
    "setup:models": "npm run build && node dist/setup/setupModels.js",
    "validate": "npm run build && node dist/setup/validateEnvironment.js",
    "lint": "eslint src/**/*.ts",
    "test": "jest"
  },
  "keywords": [
    "LLM",
    "orchestration",
    "offline",
    "GGUF",
    "llama.cpp"
  ],
  "author": "LunaBlue Contributors",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.3.1",
    "electron": "^41.2.0",
    "express": "^4.18.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
