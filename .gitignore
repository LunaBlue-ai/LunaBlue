# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/

# Node
node_modules/
frontend/dist/

# Build artifacts — built frontend copied into backend/app/static at build time
backend/app/static/*
!backend/app/static/.gitkeep

# Model files (large binaries fetched by scripts/download_model)
models/*.gguf
models/*.bin
models/*.partial

# SQLite audit database (created on first start) + WAL siblings
data/
*.db-wal
*.db-shm

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
