{
  "application": {
    "name": "LunaBlue",
    "version": "0.1.0",
    "environment": "development"
  },
  "server": {
    "port": 3000,
    "host": "localhost",
    "cors": {
      "enabled": true,
      "origin": "*"
    }
  },
  "logging": {
    "level": "info",
    "format": "json",
    "file": "logs/lunablue.log"
  },
  "paths": {
    "models": "./models",
    "config": "./config",
    "logs": "./logs",
    "temp": "./temp"
  },
  "startup": {
    "validate_environment": true,
    "auto_download_models": false,
    "start_default_model": true,
    "preload_donoharm": true
  }
}
