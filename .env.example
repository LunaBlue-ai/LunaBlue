# LunaBlue environment configuration
# Copy this file to .env and adjust for your machine. Values shown are safe
# development defaults. The .env file is gitignored — never commit real secrets.

# ── SQLite (audit/log store) ────────────────────────────────────────────────
# The audit database is a local SQLite file, created automatically on first
# start (schema applied via Alembic in the app lifespan) — no server, no
# Docker, nothing to install. Relative paths are anchored at the repository
# root; WAL sibling files (*.db-wal, *.db-shm) appear next to it. The
# default below works as-is; uncomment only to relocate the file.
#DATABASE_URL=sqlite+aiosqlite:///./data/lunablue.db

# ── LLM runtime ─────────────────────────────────────────────────────────────
# Path to the local GGUF model file (fetched by scripts/download_model, Step 7).
MODEL_PATH=./models/model.gguf

# Context window size (tokens) passed to llama-cpp-python.
LLM_CONTEXT_SIZE=4096

# Number of model layers to offload to the GPU. 0 = CPU only (safe default),
# -1 = offload all layers. Values other than 0 require a GPU-enabled
# llama-cpp-python build (see backend/README.md, "Install variants") — on a
# CPU-only build llama.cpp silently runs on CPU; the runtime logs a warning
# and /api/health/ready reports gpu_offload_supported=false.
# scripts/setup sets this to -1 automatically when it installs a verified
# GPU build (only when the value here is absent or 0).
LLM_GPU_LAYERS=0

# Default generation limits; individual calls may override them.
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7

# ── Embeddings & semantic search ────────────────────────────────────────────
# A second small GGUF model embeds stored prompts/responses into the
# sqlite-vec store for GET /api/search. Optional enhancement: a missing
# model file logs a warning and disables the feature — it never blocks
# startup. Fetch the default model with scripts/download_embedding_model.
EMBEDDING_ENABLED=true
EMBEDDING_MODEL_PATH=./models/embedding.gguf
EMBEDDING_CONTEXT_SIZE=2048
# GPU offload for the embedding model (same semantics as LLM_GPU_LAYERS).
# scripts/setup sets this to -1 automatically when it installs a verified
# GPU build (only when the value here is absent or 0).
EMBEDDING_GPU_LAYERS=0
# Stored vector size (1-768). The default model (nomic-embed-text-v1.5) is
# Matryoshka-trained: truncating its 768-dim output to 512 keeps
# near-identical retrieval quality at 2/3 the storage. Changing this after
# vectors exist requires re-embedding (see backend/README.md).
EMBEDDING_DIMENSIONS=512

# Maximum wall-clock time (seconds) a single generation may take before the
# request is failed (500, status="failed") and the failure audited.
LLM_TIMEOUT_SECONDS=120

# Per-call guard on every LlamaRuntime.generate() call — foreground and
# background agents alike. On timeout the run/agent fails cleanly with an
# audited event; the abandoned inference thread keeps the model lock until it
# finishes so nothing enters llama.cpp concurrently. 0 disables the guard.
LLM_GENERATION_TIMEOUT_SECONDS=120

# Busy guard: when this many generations are already in flight or queued on
# the runtime, new prompt submissions get an immediate 503 (code="busy")
# instead of queuing unboundedly. 0 disables the guard.
LLM_MAX_QUEUE_DEPTH=16

# ── Closed-loop prompt processing ───────────────────────────────────────────
# Both features are internal to LunaBlue: the user only ever sees the raw
# prompt and the final response — the enhanced prompt and the rolling summary
# never appear in API responses, WebSocket frames, or the UI.

# LLM prompt enhancement: rewrite the governance-reviewed prompt into a
# clearer, more complete prompt (one extra foreground LLM call per request).
# On enhancement failure the run continues with the reviewed prompt unchanged.
PROMPT_ENHANCEMENT_ENABLED=true
PROMPT_ENHANCEMENT_MAX_TOKENS=512

# Rolling per-session chat summary: injected into the enhanced prompt under a
# "### Chat Summary" heading and re-summarized in the background after each
# completed turn. Held in memory per session — lost on restart by design
# (the frontend starts a fresh session per page load anyway).
SESSION_SUMMARY_ENABLED=true
SESSION_SUMMARY_MAX_CHARS=2000
SESSION_SUMMARY_MAX_TOKENS=600

# Identity fields pinned into every injected chat summary: the "minimum
# viable persona" that survives summary resets. Stored outside the
# LLM-maintained rolling buffer (re-summarization can never drop them),
# prepended at injection time, and editable at runtime via PUT /api/identity
# (in-memory override, lost on restart). Max 200 characters each; empty
# fields are omitted. Only take effect while SESSION_SUMMARY_ENABLED=true.
IDENTITY_NAME=
IDENTITY_AGE=
IDENTITY_OCCUPATION=
IDENTITY_PERSONALITY=
IDENTITY_INTERESTS=

# ── Server ──────────────────────────────────────────────────────────────────
# Bind address and port for the FastAPI process.
HOST=127.0.0.1
PORT=8000

# Enable the WebSocket endpoint for live state updates (frontend falls back to
# polling when disabled).
WS_ENABLED=true

# Heartbeat interval (seconds) on /ws: the server sends a ping so dead
# connections are detected and reaped. 0 disables heartbeats.
WS_HEARTBEAT_SECONDS=30

# When true, startup validation also connects to Postgres and aborts boot if
# it does not answer. Off by default: the audit layer tolerates outages, so a
# down database normally degrades readiness instead of blocking boot.
STARTUP_VALIDATE_DB=false

# ── Runtime state ───────────────────────────────────────────────────────────
# How many completed/failed prompt runs the in-memory state store retains
# before evicting the oldest (evicted runs 404 from /api/runs/{id}; the
# Postgres audit chain remains the durable record). In-flight runs are never
# evicted.
STATE_MAX_FINISHED_RUNS=256
# Same retention window for settled (completed/failed/cancelled) background
# agents. Evicted agents disappear from live state but GET /api/agents/{id}
# reconstructs them from the agent_events audit record. Pending/running
# agents are never evicted.
STATE_MAX_FINISHED_AGENTS=256

# ── Background agents ───────────────────────────────────────────────────────
# Number of concurrent background-agent workers executing spawned agent
# subgraphs. Agents share the single LLM runtime (foreground prompt requests
# keep priority), so 1 is a sensible default on CPU-only machines.
AGENT_WORKERS=1

# Runaway-agent guards: wall-clock budget (seconds) per agent execution and
# the maximum LLM calls one agent may make. Agents over budget are cancelled
# (timeout) or failed (step limit), audited either way. 0 disables a guard.
AGENT_TIMEOUT_SECONDS=600
AGENT_MAX_STEPS=16

# ── Audit pipeline ──────────────────────────────────────────────────────────
# Bounded audit queue size. When Postgres is down events accumulate here;
# on overflow the oldest event is dropped (most recent are kept).
AUDIT_MAX_QUEUE_SIZE=1000

# How often (seconds) sustained overflow is reported: one aggregate ERROR per
# interval with the drop count, instead of one log line per dropped event.
AUDIT_DROP_LOG_INTERVAL_SECONDS=30

# Redact secrets/PII before audit rows are written. When enabled, well-known
# token shapes (API keys, bearer tokens, private keys) are masked in
# raw_prompt/reviewed_prompt/llm_output/final_output — the audit record then
# stores redacted text and the original input is unrecoverable from it (see
# docs/DataRetention.md for the trade-off).
AUDIT_REDACTION_ENABLED=false

# Extra regex patterns to mask on top of the built-ins, as a JSON array of
# strings, e.g. ["\\b\\d{3}-\\d{2}-\\d{4}\\b"] for US SSNs.
AUDIT_REDACTION_PATTERNS=[]

# Retention window (days) for audit rows, applied by scripts/retention
# (deletes rows older than the window; 0 keeps rows forever). Per-table
# overrides as a JSON object, e.g. {"agent_events": 30}.
AUDIT_RETENTION_DAYS=0
AUDIT_RETENTION_OVERRIDES={}

# ── Governance & logging ────────────────────────────────────────────────────
# When true, prompts that fail governance intake checks are rejected instead of
# being annotated and passed through.
GOVERNANCE_STRICT_MODE=false

# Maximum prompt length (characters) enforced by governance intake after
# normalization. Prompts over the limit are rejected, not truncated.
GOVERNANCE_MAX_PROMPT_LENGTH=32000

# Python logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
